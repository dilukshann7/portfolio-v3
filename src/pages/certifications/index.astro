---
import { certifications } from "../../data/certifications";
import TerminalTextReveal from "../../components/TerminalTextReveal.astro";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Verified certifications earned by Dilukshan Niranjan." />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>Certifications — Dilukshan Niranjan</title>
		<ClientRouter />
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<a class="wordmark" href="/" aria-label="Dilukshan Niranjan home">DN<span>.</span></a>
				<nav aria-label="Primary navigation">
					<a href="/#work">Work</a>
					<a href="/#expertise">Expertise</a>
					<a href="/certifications/" aria-current="page">Certifications</a>
					<a href="/#contact">Contact</a>
				</nav>
				<a class="header-button dark" href="/#contact">＋</a>
			</header>

			<main>
				<section class="intro">
					<p class="section-kicker">01 / Credentials</p>
					<div class="intro-grid"><h1>Proof of<br />progress.</h1><p>A living record of the courses, specializations, and practical skills I’ve completed across AI engineering, frontend development, programming, and APIs.</p></div>
				</section>

				<section class="certifications" aria-label="Verified certifications">
					<div class="section-heading"><p class="section-kicker">02 / Verified learning</p><p class="section-note">{certifications.length} credentials · 2024–2025</p></div>
					<div class="credential-list">
						{certifications.map((certification, index) => (
							<details class="credential-card" open={index === 0}>
								<summary>
									<span class="issuer-logo"><img src={certification.logo} alt={`${certification.issuer} logo`} /></span>
									<span class="credential-main"><span class="credential-title">{certification.title}</span><span class="credential-issuer">{certification.issuer}</span></span>
									<span class="credential-date">Issued {certification.issued}{certification.expires ? ` · Expires ${certification.expires}` : ""}</span>
									<span class="summary-arrow" aria-hidden="true">＋</span>
								</summary>
								<div class="credential-detail">
									<div class="detail-copy"><p class="detail-label">Credential ID</p><p class="credential-id">{certification.credentialId}</p><p class="detail-label skills-label">Skills</p><div class="skills">{certification.skills.map((skill) => <span>{skill}</span>)}</div><div class="verification-links"><a class="verify-button" href={certification.verificationUrl} target="_blank" rel="noreferrer">Verify credential <span>↗</span></a><a class="linkedin-button" href={certification.linkedinUrl} target="_blank" rel="noreferrer">View LinkedIn record <span>↗</span></a></div></div>
									{certification.certificateImage && <a class="certificate-preview" href={certification.verificationUrl} target="_blank" rel="noreferrer"><img src={certification.certificateImage} alt={`${certification.title} certificate`} loading="lazy" /><span>Open verification ↗</span></a>}
								</div>
							</details>
						))}
					</div>
				</section>
			</main>

			<footer class="footer" id="contact">
				<div><p class="section-kicker">03 / Start a conversation</p><h2>Have something<br />in mind?</h2></div>
				<div class="footer-contact"><a class="email-link" href="mailto:info@dilukshan.dev">info@dilukshan.dev <span>↗</span></a><div class="footer-links"><a href="https://www.pinterest.com/dilukshandev/" target="_blank" rel="noreferrer">Pinterest</a><a href="https://www.behance.net/Dilukshan/services" target="_blank" rel="noreferrer">Behance</a><a href="https://instagram.com/dilukshan.dev" target="_blank" rel="noreferrer">Instagram</a><a href="https://github.com/dilukshann7" target="_blank" rel="noreferrer">GitHub</a><a href="https://linkedin.com/in/dilukshann7" target="_blank" rel="noreferrer">LinkedIn</a><a href="https://x.com/dilukshann7" target="_blank" rel="noreferrer">X / Twitter</a></div></div>
			</footer>
		</div>
		<TerminalTextReveal />
	</body>
</html>

<style>
	:root { font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", sans-serif; color: #111; background: #f7f7f3; font-synthesis: none; }
	* { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { margin: 0; min-width: 320px; background: #f7f7f3; }
	a { color: inherit; text-decoration: none; }
	.page-shell { width: 100%; margin: 0; background: #f7f7f3; }
	.site-header { position: sticky; top: 0; z-index: 10; min-height: 90px; padding: 0 6.5%; display: flex; align-items: center; justify-content: space-between; gap: 28px; background: rgba(255,255,255,.82); backdrop-filter: blur(18px) saturate(150%); -webkit-backdrop-filter: blur(18px) saturate(150%); box-shadow: 0 10px 26px rgba(17,17,17,.035); }
	.wordmark { font-size: 20px; font-weight: 600; letter-spacing: -.08em; }
	.wordmark span { color: #70706b; }
	nav { display: flex; align-items: center; gap: clamp(18px, 2.1vw, 34px); margin: 0 auto; }
	nav a, .section-kicker, .section-note, .detail-label { font-size: 12px; line-height: 1.35; }
	nav a { color: #55554f; }
	.header-button { min-width: 30px; padding: 8px 9px; border: 1px solid #111; border-radius: 7px; color: #fff; background: #111; font-size: 12px; text-align: center; }
	.intro { padding: 134px 8.5% 112px; background: #fff; }
	.section-kicker { margin: 0 0 20px; color: #8d8d85; text-transform: uppercase; letter-spacing: .08em; }
	.intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10%; align-items: end; }
	h1, h2, h3, p { margin: 0; }
	h1 { font-size: clamp(58px, 8vw, 120px); font-weight: 400; line-height: .9; letter-spacing: -.085em; }
	.intro-grid > p { max-width: 500px; padding-bottom: 6px; color: #85857e; font-size: 17px; line-height: 1.6; }
	.certifications { padding: 100px 8.5% 120px; background: #f5f5f0; }
	.section-heading { display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; margin-bottom: 40px; }
	.section-note { color: #999990; }
	.credential-list { border-top: 1px solid #dcdcd5; }
	.credential-card { border-bottom: 1px solid #dcdcd5; }
	.credential-card summary { min-height: 104px; padding: 20px 0; display: grid; grid-template-columns: 54px minmax(240px, 1fr) minmax(220px, .75fr) 24px; gap: 20px; align-items: center; cursor: pointer; list-style: none; transition: padding .25s cubic-bezier(.2,.8,.2,1), background .2s ease; }
	.credential-card summary::-webkit-details-marker { display: none; }
	.credential-card summary:hover { padding-left: 12px; padding-right: 12px; background: #efefe9; }
	.issuer-logo { width: 50px; height: 50px; display: grid; place-items: center; border: 1px solid #e1e1da; border-radius: 12px; background: #fff; }
	.issuer-logo img { width: 32px; height: 32px; object-fit: contain; }
	.credential-main { display: grid; gap: 7px; }
	.credential-title { font-size: clamp(19px, 2.1vw, 29px); line-height: 1.05; letter-spacing: -.06em; }
	.credential-issuer { color: #8c8c84; font-size: 14px; }
	.credential-date { color: #87877f; font-size: 13px; line-height: 1.45; }
	.summary-arrow { justify-self: end; font-size: 19px; transition: transform .3s ease; }
	.credential-card[open] .summary-arrow { transform: rotate(45deg); }
	.credential-detail { padding: 4px 0 28px 74px; display: grid; grid-template-columns: minmax(260px, 1fr) minmax(280px, .8fr); gap: 42px; }
	.detail-copy { padding-top: 2px; }
	.detail-label { margin-bottom: 8px; color: #989890; text-transform: uppercase; letter-spacing: .08em; }
	.credential-id { color: #272722; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 13px; line-height: 1.5; word-break: break-all; }
	.skills-label { margin-top: 26px; }
	.skills { display: flex; flex-wrap: wrap; gap: 8px; }
	.skills span { padding: 8px 10px; border: 1px solid #dfdfd8; border-radius: 999px; color: #77776f; background: #fafaf7; font-size: 12px; }
	.verification-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 30px; }
	.verify-button, .linkedin-button { display: inline-flex; align-items: center; gap: 16px; padding: 12px 14px; border-radius: 7px; font-size: 13px; }
	.verify-button { color: #fff; background: #111; }
	.linkedin-button { border: 1px solid #dcdcd5; background: #fff; }
	.certificate-preview { position: relative; display: block; overflow: hidden; border-radius: 8px; background: #e8e8e1; }
	.certificate-preview img { width: 100%; height: 220px; display: block; object-fit: cover; opacity: .95; transition: transform .45s cubic-bezier(.2,.8,.2,1); }
	.certificate-preview:hover img { transform: scale(1.04); }
	.certificate-preview span { position: absolute; right: 12px; bottom: 12px; padding: 7px 9px; border-radius: 5px; color: #fff; background: rgba(17,17,17,.82); font-size: 11px; backdrop-filter: blur(8px); }
	.footer { min-height: 560px; padding: 142px 8.5% 104px; display: grid; grid-template-columns: 1.1fr .9fr; gap: 10%; align-items: center; color: #fff; background: #111; }
	.footer .section-kicker { color: #8e8e87; }
	.footer h2 { max-width: 820px; font-size: clamp(46px, 6.5vw, 98px); font-weight: 400; line-height: .94; letter-spacing: -.085em; }
	.footer-contact { align-self: center; }
	.email-link { display: inline-flex; align-items: center; gap: 20px; padding-bottom: 13px; border-bottom: 1px solid #777; font-size: clamp(22px, 2vw, 30px); letter-spacing: -.05em; }
	.email-link span { font-size: 16px; }
	.footer-links { display: flex; flex-wrap: wrap; gap: 22px; margin-top: 28px; color: #a2a29c; font-size: 15px; }
	@media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } *, *::before, *::after { transition-duration: .01ms !important; } }
	@media (prefers-reduced-transparency: reduce) { .site-header { background: #fff; backdrop-filter: none; -webkit-backdrop-filter: none; box-shadow: 0 1px 0 #f0f0eb; } .certificate-preview span { background: #111; } }
	@media (max-width: 820px) {
		.site-header { min-height: 72px; padding: 0 7%; }
		nav { gap: 12px; }
		nav a:nth-child(n+3) { display: none; }
		.intro { padding: 86px 9% 78px; }
		.intro-grid { grid-template-columns: 1fr; gap: 34px; }
		.intro-grid > p { font-size: 16px; }
		.certifications { padding: 76px 9% 88px; }
		.section-heading { display: block; }
		.section-note { margin-top: 24px; }
		.credential-card summary { grid-template-columns: 48px 1fr 24px; gap: 14px; }
		.issuer-logo { width: 44px; height: 44px; border-radius: 10px; }
		.issuer-logo img { width: 27px; height: 27px; }
		.credential-date { grid-column: 2; font-size: 12px; }
		.summary-arrow { grid-column: 3; grid-row: 1 / span 2; }
		.credential-detail { padding: 4px 0 28px 62px; grid-template-columns: 1fr; gap: 26px; }
		.certificate-preview img { height: 190px; }
		.footer { grid-template-columns: 1fr; gap: 54px; min-height: 560px; padding: 112px 9% 84px; }
		.footer-contact { align-self: start; }
	}
	@media (max-width: 500px) { nav { display: none; } .credential-card summary { grid-template-columns: 42px 1fr 22px; } .issuer-logo { width: 40px; height: 40px; } .issuer-logo img { width: 24px; height: 24px; } .credential-title { font-size: 20px; } .credential-detail { padding-left: 0; } .verification-links { display: grid; } .verify-button, .linkedin-button { justify-content: space-between; } }
</style>
