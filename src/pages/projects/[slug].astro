---
import { projects } from "../../data/projects";
import TerminalTextReveal from "../../components/TerminalTextReveal.astro";
import { ClientRouter } from "astro:transitions";

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const otherProjects = projects.filter((item) => item.slug !== project.slug).slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={`${project.name} — ${project.description}`} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{project.name} — Dilukshan Niranjan</title>
		<ClientRouter />
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<a class="wordmark" href="/" aria-label="Dilukshan Niranjan home">DN<span>.</span></a>
				<nav aria-label="Project navigation">
					<a href="/projects/">All projects</a>
					<a href="/#expertise">Expertise</a>
					<a href="/#contact">Contact</a>
				</nav>
				<a class="header-button dark" href="/projects/">↖</a>
			</header>

			<main>
				<section class="project-hero">
					<a class="back-link" href="/projects/">← All projects</a>
					<div class="hero-grid">
						<div><p class="section-kicker">{project.year} / {project.status}</p><h1>{project.name}</h1><p class="hero-description">{project.description}</p></div>
						<div class="hero-meta">
							<div><span class="meta-label">System</span><strong>{project.system}</strong></div>
							<div><span class="meta-label">Role</span><strong>{project.role}</strong></div>
							<div class="project-links">
								{project.links.map((link) => <a class="project-link" data-link-type={link.type} href={link.href} target="_blank" rel="noreferrer">{link.label} <span>↗</span></a>)}
							</div>
						</div>
					</div>
					<img class="project-cover" src={project.image} alt={`${project.name} project preview`} />
				</section>

				<section class="project-notes">
					<div><p class="section-kicker">01 / Project note</p><h2>Designed, built,<br />and refined.</h2></div>
					<div class="note-copy"><p>{project.details}</p><p>I worked on the product, UI/UX, and engineering from the first flow to the final build.</p><div class="project-facts"><div><span>Platform</span><strong>{project.platform}</strong></div><div><span>Focus</span><strong>{project.focus}</strong></div></div><p class="detail-label">What stands out</p><ul class="highlight-list">{project.highlights.map((highlight) => <li>{highlight}</li>)}</ul><p class="detail-label stack-label">Technology stack</p><div class="stack-list" aria-label={`${project.name} technology stack`} data-no-text-reveal>{project.stack.map((technology) => <div class="stack-item"><span class="stack-icon" aria-hidden="true"><img src={technology.icon} alt="" /></span><span class="stack-name">{technology.name}</span></div>)}</div><a class="text-link" href="mailto:info@dilukshan.dev">Start a conversation <span>↗</span></a></div>
				</section>

				<section class="more-projects">
					<div class="section-heading-row"><div><p class="section-kicker">02 / More work</p><h2>Keep exploring</h2></div><a class="small-button" href="/projects/">View all projects <span>↗</span></a></div>
					<div class="more-grid">
						{otherProjects.map((item) => <a class="more-card" href={`/projects/${item.slug}/`}><img src={item.image} alt={`${item.name} project preview`} loading="lazy" /><div><p class="project-meta">{item.year} · {item.status}</p><h3>{item.name}</h3><span>View project ↗</span></div></a>)}
					</div>
				</section>
			</main>

			<footer class="footer" id="contact">
				<div><p class="section-kicker">03 / Start a conversation</p><h2>Have something<br />in mind?</h2></div>
				<div class="footer-contact"><a class="email-link" href="mailto:info@dilukshan.dev">info@dilukshan.dev <span>↗</span></a><div class="footer-links"><a href="https://www.pinterest.com/dilukshandev/" target="_blank" rel="noreferrer">Pinterest</a><a href="https://www.behance.net/Dilukshan/services" target="_blank" rel="noreferrer">Behance</a><a href="https://instagram.com/dilukshan.dev" target="_blank" rel="noreferrer">Instagram</a><a href="https://github.com/dilukshann7" target="_blank" rel="noreferrer">GitHub</a><a href="https://linkedin.com/in/dilukshann7" target="_blank" rel="noreferrer">LinkedIn</a><a href="https://x.com/dilukshann7" target="_blank" rel="noreferrer">X / Twitter</a></div></div>
			</footer>
		</div>
		<TerminalTextReveal />
	</body>
</html>

<style>
	:root { font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", sans-serif; color: #111; background: #f7f7f3; font-synthesis: none; }
	* { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { margin: 0; min-width: 320px; overflow-x: clip; background: #f7f7f3; }
	a { color: inherit; text-decoration: none; }
	.page-shell { width: 100%; margin: 0; background: #f7f7f3; }
	.site-header { position: sticky; top: 0; z-index: 10; min-height: 90px; padding: 0 6.5%; display: flex; align-items: center; justify-content: space-between; gap: 28px; border-bottom: 1px solid rgba(17,17,17,.08); background: radial-gradient(ellipse at 14% -80%, rgba(255,255,255,.98) 0%, rgba(255,255,255,.58) 34%, transparent 62%), radial-gradient(ellipse at 86% 180%, rgba(214,224,232,.4) 0%, transparent 55%), linear-gradient(110deg, rgba(255,255,255,.74) 0%, rgba(238,243,247,.48) 52%, rgba(255,255,255,.72) 100%); backdrop-filter: blur(30px) saturate(190%) contrast(104%); -webkit-backdrop-filter: blur(30px) saturate(190%) contrast(104%); box-shadow: inset 0 1px 0 rgba(255,255,255,.96), inset 0 -1px 0 rgba(255,255,255,.45), 0 14px 34px rgba(17,17,17,.085); }
	.wordmark { font-size: 20px; font-weight: 600; letter-spacing: -.08em; }
	.wordmark span { color: #70706b; }
	nav { display: flex; align-items: center; gap: 28px; margin: 0 auto; }
	nav a, .section-kicker, .project-meta { font-size: 12px; line-height: 1.35; }
	nav a { color: #55554f; }
	.header-button { min-width: 30px; padding: 8px 9px; border: 1px solid #111; border-radius: 7px; color: #fff; background: #111; font-size: 13px; text-align: center; }
	.project-hero { padding: 62px 8.5% 108px; background: #fff; }
	.back-link { display: inline-flex; gap: 8px; color: #77776f; font-size: 13px; }
	.hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 10%; align-items: end; padding: 108px 0 70px; }
	.section-kicker { margin: 0 0 20px; color: #8d8d85; text-transform: uppercase; letter-spacing: .08em; }
	h1, h2, h3, p { margin: 0; }
	h1 { font-size: clamp(64px, 10vw, 150px); font-weight: 400; line-height: .88; letter-spacing: -.09em; }
	.hero-description { max-width: 620px; margin-top: 28px; color: #85857e; font-size: 18px; line-height: 1.55; }
	.hero-meta { display: grid; gap: 22px; padding-bottom: 8px; }
	.hero-meta > div { display: grid; gap: 8px; }
	.meta-label { color: #9a9a92; font-size: 12px; text-transform: uppercase; letter-spacing: .08em; }
	.hero-meta strong { max-width: 360px; font-size: 25px; font-weight: 400; line-height: 1.08; letter-spacing: -.05em; }
	.project-links { display: flex !important; grid-auto-flow: unset; flex-wrap: wrap; gap: 9px !important; margin-top: 10px; }
	.project-link { display: inline-flex; align-items: center; justify-content: space-between; gap: 20px; padding: 11px 13px; border: 1px solid #dcdcd5; border-radius: 7px; color: #61615b; background: #fafaf7; font-size: 13px; transition: transform .25s cubic-bezier(.2,.8,.2,1), border-color .2s ease, background .2s ease, color .2s ease; }
	.project-link[data-link-type="live"] { color: #fff; border-color: #111; background: #111; }
	.project-link:hover { transform: translateY(-2px); border-color: #bcbcb4; }
	.project-link[data-link-type="live"]:hover { border-color: #2d2d29; background: #2d2d29; }
	.project-link span, .text-link span, .small-button span, .email-link span { font-size: 17px; }
	.project-cover { width: 100%; height: min(58vw, 720px); display: block; object-fit: cover; border-radius: 8px; background: #e6e5de; }
	.project-notes, .more-projects { padding: 112px 8.5%; background: #f5f5f0; }
	.project-notes { display: grid; grid-template-columns: 1fr 1fr; gap: 10%; }
	.project-notes h2, .more-projects h2 { font-size: clamp(38px, 4.8vw, 70px); font-weight: 400; line-height: .95; letter-spacing: -.08em; }
	.note-copy { max-width: 540px; padding-top: 38px; }
	.note-copy p { color: #85857e; font-size: 17px; line-height: 1.6; }
	.note-copy p + p { margin-top: 20px; }
	.project-facts { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 34px; padding-top: 20px; border-top: 1px solid #dcdcd5; }
	.project-facts div { display: grid; gap: 8px; }
	.project-facts span, .detail-label { color: #989890; font-size: 12px; text-transform: uppercase; letter-spacing: .08em; }
	.project-facts strong { font-size: 16px; font-weight: 400; line-height: 1.25; }
	.detail-label { margin-top: 32px; }
	.highlight-list { margin: 12px 0 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; list-style: none; }
	.highlight-list li { position: relative; padding-left: 16px; color: #77776f; font-size: 14px; line-height: 1.4; }
	.highlight-list li::before { content: '↗'; position: absolute; left: 0; color: #111; }
	.stack-label { margin-top: 26px; }
	.stack-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 24px; margin-top: 14px; border-top: 1px solid #deded7; }
	.stack-item { width: 100%; min-width: 0; min-height: 48px; padding: 11px 0; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid #deded7; color: #66665f; font-size: 12px; line-height: 1; transition: color .25s ease, transform .3s cubic-bezier(.22,.61,.36,1); }
	.stack-item:hover { color: #111; transform: translateX(3px); }
	.stack-icon { width: 22px; height: 22px; min-width: 22px; max-width: 22px; min-height: 22px; max-height: 22px; display: grid; place-items: center; flex: 0 0 22px; overflow: hidden; }
	.stack-icon img { width: 20px !important; height: 20px !important; min-width: 0; max-width: 20px; max-height: 20px; display: block; object-fit: contain; }
	.stack-name { display: block; white-space: nowrap; }
	.text-link { display: inline-flex; align-items: center; gap: 18px; margin-top: 32px; padding-bottom: 9px; border-bottom: 1px solid #111; font-size: 14px; }
	.more-projects { padding-top: 0; }
	.section-heading-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 42px; }
	.small-button { display: inline-flex; align-items: center; gap: 18px; padding: 11px 14px; border: 1px solid #deded7; border-radius: 7px; color: #77776f; background: #fafaf7; font-size: 13px; }
	.more-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
	.more-card { display: block; background: #fff; border-radius: 8px; overflow: hidden; transition: transform .25s cubic-bezier(.2,.8,.2,1); }
	.more-card:hover { transform: translateY(-5px); }
	.more-card:active { transform: scale(.98); }
	.more-card img { width: 100%; height: 190px; display: block; object-fit: cover; background: #e6e5de; }
	.more-card > div { padding: 19px 20px 22px; }
	.more-card .project-meta { color: #96968e; }
	.more-card h3 { margin: 12px 0 20px; font-size: 23px; font-weight: 400; letter-spacing: -.06em; }
	.more-card > div > span { color: #77776f; font-size: 13px; }
	.footer { min-height: 560px; padding: 142px 8.5% 104px; display: grid; grid-template-columns: 1.1fr .9fr; gap: 10%; align-items: center; color: #fff; background: #111; }
	.footer .section-kicker { color: #8e8e87; }
	.footer h2 { max-width: 820px; font-size: clamp(46px, 6.5vw, 98px); font-weight: 400; line-height: .94; letter-spacing: -.085em; }
	.footer-contact { align-self: center; }
	.email-link { display: inline-flex; align-items: center; gap: 20px; padding-bottom: 13px; border-bottom: 1px solid #777; font-size: clamp(22px, 2vw, 30px); letter-spacing: -.05em; }
	.footer-links { display: flex; flex-wrap: wrap; gap: 22px; margin-top: 28px; color: #a2a29c; font-size: 15px; }
	@media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } *, *::before, *::after { transition-duration: .01ms !important; } .more-card:hover { transform: none; } }
	@media (prefers-reduced-transparency: reduce) { .site-header { border-bottom-color: #f0f0eb; background: #fff; backdrop-filter: none; -webkit-backdrop-filter: none; box-shadow: none; } }
	@media (max-width: 760px) {
		.site-header { min-height: 72px; padding: 0 7%; }
		.header-button { width: 44px; min-width: 44px; height: 44px; padding: 0; display: grid; place-items: center; }
		nav { gap: 12px; }
		nav a:nth-child(n+2) { display: none; }
		.project-hero { padding: 42px 9% 72px; }
		.hero-grid, .project-notes, .footer { grid-template-columns: 1fr; gap: 54px; }
		.hero-grid { padding: 82px 0 52px; }
		h1 { max-width: 100%; overflow-wrap: anywhere; font-size: clamp(54px, 15vw, 92px); }
		.hero-description { font-size: 16px; }
		.project-link { min-height: 46px; }
		.project-cover { height: auto; aspect-ratio: 16 / 10; }
		.project-notes, .more-projects { padding-left: 9%; padding-right: 9%; }
		.note-copy { padding-top: 0; }
		.project-facts { gap: 12px; }
		.highlight-list { grid-template-columns: 1fr; }
		.section-heading-row { display: block; }
		.small-button { margin-top: 22px; }
		.more-grid { grid-template-columns: 1fr; }
		.more-card img { height: auto; aspect-ratio: 16 / 10; }
		.footer { min-height: 0; padding: 96px 9% 76px; }
		.footer-contact { align-self: start; }
	}
	@media (max-width: 500px) {
		.site-header { min-height: 64px; padding: 0 clamp(20px, 6.5vw, 28px); }
		nav { display: none; }
		.project-hero { padding: 32px clamp(20px, 6.5vw, 28px) 64px; }
		.back-link { min-height: 44px; align-items: center; }
		.hero-grid { padding: 56px 0 42px; gap: 42px; }
		h1 { font-size: clamp(50px, 15vw, 76px); }
		.hero-description { margin-top: 22px; line-height: 1.65; }
		.hero-meta strong { font-size: 22px; }
		.project-links { display: grid !important; grid-template-columns: 1fr; }
		.project-link { width: 100%; }
		.project-cover { border-radius: 6px; }
		.project-notes, .more-projects { padding: 76px clamp(20px, 6.5vw, 28px); }
		.project-notes { gap: 40px; }
		.project-notes h2, .more-projects h2 { font-size: clamp(38px, 12vw, 50px); text-wrap: balance; }
		.note-copy p { font-size: 16px; line-height: 1.65; }
		.stack-list { grid-template-columns: 1fr; }
		.stack-name { white-space: normal; }
		.small-button { min-height: 44px; align-items: center; }
		.more-projects { padding-top: 0; }
		.more-card > div { padding: 18px 18px 22px; }
		.footer { padding: 84px clamp(20px, 6.5vw, 28px) 68px; gap: 48px; }
		.footer h2 { font-size: clamp(42px, 13vw, 58px); }
		.email-link { max-width: 100%; gap: 12px; font-size: clamp(19px, 5.8vw, 23px); }
		.footer-links { gap: 14px 20px; line-height: 1.4; }
	}
	@media (max-width: 380px) { .project-facts { grid-template-columns: 1fr; gap: 20px; } }
</style>
