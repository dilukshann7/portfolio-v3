	},
	{
		number: "02",
		title: "UI/UX design",
		text: "Interfaces, user flows, and interaction details that make complex products feel clear, useful, and considered.",
	},
	{
		number: "03",
		title: "Generative AI",
		text: "Grounded AI workflows with retrieval, citations, tool use, and product guardrails so model output stays useful.",
