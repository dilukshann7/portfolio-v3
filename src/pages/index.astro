						<a class="text-link" href="/certifications/">View all credentials <span>↗</span></a>
					</div>
					<div class="section-column certification-list" data-stagger>
						{certifications.slice(0, 6).map((certification) => <a class="certification-row" href="/certifications/"><span class="cert-mark"><img src={certification.logo} alt="" /></span><div><h3>{certification.title}</h3><p>{certification.issuer}</p></div><span class="row-arrow">↗</span></a>)}
					</div>
				</section>

			</main>

			<footer class="footer" id="contact" data-reveal>
				<div><p class="section-kicker">07 / Start a conversation</p><h2>Have a project in mind?<br />Let’s talk.</h2></div>
				<div class="footer-contact"><a class="email-link" href="mailto:info@dilukshan.dev">info@dilukshan.dev <span>↗</span></a><div class="footer-links"><a href="https://www.pinterest.com/dilukshandev/" target="_blank" rel="noreferrer">Pinterest</a><a href="https://www.behance.net/Dilukshan/services" target="_blank" rel="noreferrer">Behance</a><a href="https://instagram.com/dilukshan.dev" target="_blank" rel="noreferrer">Instagram</a><a href="https://github.com/dilukshann7" target="_blank" rel="noreferrer">GitHub</a><a href="https://linkedin.com/in/dilukshann7" target="_blank" rel="noreferrer">LinkedIn</a><a href="https://x.com/dilukshann7" target="_blank" rel="noreferrer">X / Twitter</a></div></div>
			</footer>
		</div>
		<TerminalTextReveal />
	</body>
</html>

<script>
	const root = document.documentElement;
	root.classList.add("js");

	const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const revealItems = document.querySelectorAll("[data-reveal]");
	const staggerGroups = document.querySelectorAll("[data-stagger]");
	const progressBar = document.querySelector(".scroll-progress span");

	staggerGroups.forEach((group) => {
		Array.from(group.children).forEach((child, index) => {
			child.style.setProperty("--stagger-index", String(index));
		});
	});

	if (reduceMotion || !("IntersectionObserver" in window)) {
		revealItems.forEach((item) => item.classList.add("is-visible"));
	} else {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					entry.target.classList.add("is-visible");
					observer.unobserve(entry.target);
				});
			},
			{ rootMargin: "0px 0px -10%", threshold: 0.08 },
		);

		revealItems.forEach((item) => observer.observe(item));
	}

	let scrollFrame = 0;
	const updateScrollProgress = () => {
		if (!progressBar) return;
		const scrollable = document.documentElement.scrollHeight - window.innerHeight;
		const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
		progressBar.style.transform = `scaleX(${Math.min(1, Math.max(0, progress))})`;
		scrollFrame = 0;
	};
	window.addEventListener("scroll", () => {
		if (!scrollFrame) scrollFrame = requestAnimationFrame(updateScrollProgress);
	}, { passive: true });
	updateScrollProgress();

	if (!reduceMotion && window.matchMedia("(pointer: fine)").matches) {
		for (const target of document.querySelectorAll(".button, .small-button, .header-button, .social-rail a")) {
			let x = 0;
			let y = 0;
			let targetX = 0;
			let targetY = 0;
			let frame = 0;

			const spring = () => {
				x += (targetX - x) * 0.18;
				y += (targetY - y) * 0.18;
				target.style.setProperty("--magnetic-x", `${x.toFixed(2)}px`);
				target.style.setProperty("--magnetic-y", `${y.toFixed(2)}px`);
				if (Math.abs(targetX - x) > 0.05 || Math.abs(targetY - y) > 0.05) frame = requestAnimationFrame(spring);
				else frame = 0;
			};

			target.addEventListener("pointermove", (event) => {
				const rect = target.getBoundingClientRect();
				targetX = Math.max(-4, Math.min(4, (event.clientX - (rect.left + rect.width / 2)) * 0.16));
				targetY = Math.max(-4, Math.min(4, (event.clientY - (rect.top + rect.height / 2)) * 0.16));
				if (!frame) frame = requestAnimationFrame(spring);
			});
			target.addEventListener("pointerleave", () => {
				targetX = 0;
				targetY = 0;
				if (!frame) frame = requestAnimationFrame(spring);
			});
		}
	}

	for (const control of document.querySelectorAll(".button, .small-button, .header-button, .social-rail a, .circle-arrow")) {
		control.addEventListener("pointerdown", () => control.classList.add("is-pressed"));
		for (const eventName of ["pointerup", "pointercancel", "pointerleave"]) {
			control.addEventListener(eventName, () => control.classList.remove("is-pressed"));
		}
	}
</script>

<style>
	:root { --motion-ease: cubic-bezier(.22,.61,.36,1); font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", sans-serif; color: #111; background: #f7f7f3; font-synthesis: none; }
	* { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { margin: 0; min-width: 320px; overflow-x: clip; background: #f7f7f3; }
	a { color: inherit; text-decoration: none; }
	.scroll-progress { position: fixed; top: 0; left: 0; z-index: 40; width: 100%; height: 2px; pointer-events: none; background: transparent; }
	.scroll-progress span { display: block; width: 100%; height: 100%; transform: scaleX(0); transform-origin: left center; background: #111; }
	.page-shell { width: 100%; margin: 0; background: #f7f7f3; }
	.site-header { position: sticky; top: 0; z-index: 20; min-height: 90px; padding: 0 6.5%; display: flex; align-items: center; justify-content: space-between; gap: 28px; border-bottom: 1px solid rgba(17,17,17,.08); background: radial-gradient(ellipse at 14% -80%, rgba(255,255,255,.98) 0%, rgba(255,255,255,.58) 34%, transparent 62%), radial-gradient(ellipse at 86% 180%, rgba(214,224,232,.4) 0%, transparent 55%), linear-gradient(110deg, rgba(255,255,255,.74) 0%, rgba(238,243,247,.48) 52%, rgba(255,255,255,.72) 100%); backdrop-filter: blur(30px) saturate(190%) contrast(104%); -webkit-backdrop-filter: blur(30px) saturate(190%) contrast(104%); box-shadow: inset 0 1px 0 rgba(255,255,255,.96), inset 0 -1px 0 rgba(255,255,255,.45), 0 14px 34px rgba(17,17,17,.085); }
	.wordmark { font-size: 20px; font-weight: 600; letter-spacing: -.08em; }
	.wordmark span { color: #70706b; }
	nav { display: flex; align-items: center; gap: clamp(18px, 2.1vw, 34px); margin-left: auto; margin-right: auto; }
	nav a, .header-meta, .section-kicker, .project-meta { font-size: 12px; line-height: 1.35; letter-spacing: .01em; }
	nav a { color: #55554f; transition: color .2s ease; }
	nav a:hover, .footer-links a:hover, .text-link:hover { color: #77766f; }
	.header-meta { display: flex; align-items: center; gap: 8px; color: #8e8e87; text-align: right; }
	.header-meta strong { color: #252522; font-weight: 600; font-size: 10px; }
	.header-button, .small-button { padding: 11px 14px; border: 1px solid #e9e9e3; border-radius: 7px; font-size: 12px; white-space: nowrap; }
	.header-button.muted, .small-button { color: #77776f; background: #fafaf7; }
	.header-button.dark { min-width: 26px; padding: 7px 8px; color: white; background: #111; border-color: #111; text-align: center; }
	.hero { min-height: calc(100svh - 78px); padding: 78px 10% 92px; display: grid; grid-template-columns: minmax(0, 1fr); grid-template-rows: auto auto; align-content: center; justify-items: center; row-gap: 58px; background: #fff; }
	.hero-name, .hero-copy { min-width: 0; }
	.hero-name { grid-column: 1; width: 100%; text-align: center; }
	h1, h2, h3, p { margin: 0; }
	h1 { max-width: none; white-space: nowrap; font-size: clamp(38px, 5.25vw, 84px); font-weight: 400; line-height: .95; letter-spacing: -.075em; }
	.hero-copy { grid-column: 1; width: min(100%, 760px); padding-top: 0; text-align: center; }
	.eyebrow { margin-bottom: 18px; color: #898983; font-size: 14px; }
	.hero-copy h2 { max-width: 680px; margin: 0 auto; font-size: clamp(34px, 3.4vw, 54px); font-weight: 400; line-height: 1.05; letter-spacing: -.065em; }
	.hero-description { max-width: 620px; margin: 20px auto 0; color: #8b8b84; font-size: 15px; line-height: 1.55; }
	.actions { display: flex; justify-content: center; gap: 9px; margin-top: 28px; }
	.button, .small-button, .header-button, .social-rail a { --magnetic-x: 0px; --magnetic-y: 0px; transform: translate3d(var(--magnetic-x), var(--magnetic-y), 0) scale(1); transition: transform .42s var(--motion-ease), background .3s ease, color .3s ease, border-color .3s ease; }
	.button { padding: 13px 17px; display: inline-flex; align-items: center; gap: 22px; border: 1px solid #e4e4de; border-radius: 7px; font-size: 12px; transition: transform .2s ease, background .2s ease; touch-action: manipulation; }
	.button:hover, .small-button:hover { transform: translate3d(var(--magnetic-x), calc(var(--magnetic-y) - 2px), 0); }
	.button:active, .small-button:active, .header-button:active, .social-rail a:active, .circle-arrow:active { transform: scale(.96); transition-duration: 80ms; }
	.is-pressed { transform: translate3d(var(--magnetic-x), var(--magnetic-y), 0) scale(.96) !important; transition: transform 100ms ease-out !important; }
	.button.dark { color: #fff; background: #111; border-color: #111; }
	.button.light { background: #fff; }
	.button span, .small-button span, .text-link span, .email-link span { font-size: 15px; line-height: 0; }
	.location { margin-top: 30px; color: #787870; font-size: 13px; text-align: center; }
	.location-dot { display: inline-block; width: 6px; height: 6px; margin-right: 4px; border-radius: 50%; background: #111; }
	.availability { color: #aaa9a1; }
	.social-rail { position: relative; z-index: 1; width: fit-content; margin: 26px auto 0; display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: 9px; }
	.social-rail a { width: 36px; height: 36px; display: grid; place-items: center; border: 1px solid #e7e7e1; border-radius: 50%; color: #72726b; background: #fff; transition: background .2s ease, color .2s ease, transform .2s ease; }
	.social-rail img { width: 15px; height: 15px; display: block; object-fit: contain; }
	.social-rail a:hover { color: #fff; background: #111; border-color: #111; }
	.social-rail a:hover img { filter: brightness(0) invert(1); }
	.soft-section { padding: 104px 8.5%; background: #f5f5f0; }
	.split-section { display: grid; grid-template-columns: 1fr 1fr; gap: 10%; }
	.section-kicker { margin-bottom: 20px; color: #8d8d85; text-transform: uppercase; letter-spacing: .08em; }
	.soft-section h2 { font-size: clamp(34px, 3.6vw, 52px); font-weight: 400; line-height: 1.05; letter-spacing: -.065em; }
	.second-column { padding-top: 42px; }
	.second-column h2 { margin-bottom: 22px; }
	.large-note { max-width: 460px; color: #85857e; font-size: 16px; line-height: 1.6; }
	.text-link { display: inline-flex; align-items: center; gap: 18px; margin-top: 30px; padding-bottom: 8px; border-bottom: 1px solid #111; font-size: 13px; }
	.expertise-list { margin-top: 48px; }
	.expertise-item { padding: 20px 0; display: grid; grid-template-columns: 36px 1fr; gap: 16px; border-top: 1px solid #deded7; }
	.expertise-item:last-child { border-bottom: 1px solid #deded7; }
	.item-number { color: #a2a29a; font-size: 12px; }
	.expertise-item h3, .service-row h3, .service-feature h3 { font-size: 20px; font-weight: 400; letter-spacing: -.035em; }
	.expertise-item p { max-width: 440px; margin-top: 8px; color: #96968e; font-size: 14px; line-height: 1.5; }
	.work-section { padding-top: 100px; background: #f5f5f0; }
	.section-heading-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 40px; }
	.section-heading-row h2 { margin-top: 2px; }
	.project-list { border-top: 1px solid #dcdcd5; }
	.project-row { position: relative; min-height: 104px; padding: 20px 0; display: grid; grid-template-columns: 17% 27% 1fr 28px; align-items: center; gap: 18px; border-bottom: 1px solid #dcdcd5; overflow: hidden; transform: translate3d(0, 0, 0); transition: transform .78s var(--motion-ease); touch-action: manipulation; }
	.project-row::before { content: ""; position: absolute; left: 0; bottom: 0; z-index: 2; width: 100%; height: 2px; background: #111; transform: scaleX(0); transform-origin: left center; transition: transform .78s var(--motion-ease); }
	.project-row::after { content: ""; position: absolute; inset: 0; z-index: 0; background: #ecece6; opacity: 0; transform: scale(.985); transition: opacity .42s ease, transform .72s var(--motion-ease); pointer-events: none; }
	.project-row:hover { transform: translate3d(3px, 0, 0); }
	.project-row:hover::before { transform: scaleX(1); }
	.project-row:hover::after { opacity: 1; transform: scale(1); }
	.project-row > *:not(.project-hover-preview) { position: relative; z-index: 1; transition: transform .72s var(--motion-ease), color .45s ease, opacity .45s ease; }
	.project-row:hover .project-meta { color: #111; transform: translateX(4px); }
	.project-row:hover h3 { transform: translateX(7px); }
	.project-row:hover p { color: #5f5f59; transform: translateX(4px); }
	.project-row:hover .row-arrow { transform: translate3d(-3px, -2px, 0) rotate(-45deg) scale(1.12); }
	.project-hover-preview { position: absolute; top: 50%; right: 68px; z-index: 2; width: 150px; height: 88px; overflow: hidden; border: 1px solid rgba(17,17,17,.12); border-radius: 8px; opacity: 0; pointer-events: none; will-change: transform, opacity; transform: translate3d(20px, -50%, 0) scale(.94); transition: opacity .48s ease .06s, transform .74s cubic-bezier(.4,0,.2,1); box-shadow: 0 12px 28px rgba(17,17,17,.12); }
	.project-hover-preview img { width: 100%; height: 100%; display: block; object-fit: cover; transform: scale(1.045); transition: transform .78s cubic-bezier(.4,0,.2,1); }
	.project-row:hover .project-hover-preview { opacity: 1; transform: translate3d(0, -50%, 0) scale(1); transition: opacity .42s ease, transform .82s var(--motion-ease); }
	.project-row:hover .project-hover-preview img { transform: scale(1); transition: transform .82s var(--motion-ease); }
	.expertise-item, .service-row, .certification-row { position: relative; overflow: hidden; transform: translate3d(0, 0, 0); transition: transform .7s var(--motion-ease); }
	.expertise-item::before, .service-row::before, .certification-row::before { content: ""; position: absolute; inset: 0; z-index: 0; background: #ecece6; opacity: 0; transform: scale(.985); transition: opacity .4s ease, transform .7s var(--motion-ease); pointer-events: none; }
	.expertise-item > *, .service-row > *, .certification-row > * { position: relative; z-index: 1; }
	.expertise-item:hover, .service-row:hover, .certification-row:hover { transform: translate3d(4px, 0, 0); }
	.expertise-item:hover::before, .service-row:hover::before, .certification-row:hover::before { opacity: 1; transform: scale(1); }
	.expertise-item:hover h3, .service-row:hover h3, .certification-row:hover h3 { transform: translateX(4px); }
	.expertise-item h3, .service-row h3, .certification-row h3 { transition: transform .7s var(--motion-ease); }
	.service-row:hover .circle-arrow, .certification-row:hover .row-arrow { transform: rotate(-45deg) scale(1.12); }
	.circle-arrow, .certification-row .row-arrow { transition: transform .7s var(--motion-ease); }
